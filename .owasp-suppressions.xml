<?xml version="1.0" encoding="UTF-8"?>
<!--
  .owasp-suppressions.xml
  OWASP Dependency-Check false-positive suppressions.

  POLICY: Every suppression MUST have:
    1. A <notes> element with justification and ticket reference
    2. An expiry date (max 90 days) — review before it expires
    3. The specific CVE or vulnerability ID being suppressed

  Suppress by the most specific identifier available (CVE > GAV > filePath).
  Never use broad wildcard suppressions.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

  <!--
    TEMPLATE — copy this block for new suppressions:

    <suppress until="YYYY-MM-DD">
      <notes>
        Justification: [why this is a false positive or accepted risk]
        Ticket: [JIRA/GitHub issue URL]
        Reviewed by: [engineer name]
      </notes>
      <cve>CVE-YYYY-NNNNN</cve>
      <gav regex="false">groupId:artifactId:version</gav>
    </suppress>
  -->

</suppressions>
